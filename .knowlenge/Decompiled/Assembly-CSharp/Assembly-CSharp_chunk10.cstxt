		{
			return;
		}
		if (LoadMode == AILoadMode.LoadAi)
		{
			SetupAI(baseBoat);
		}
		if (LoadMode == AILoadMode.KillAi)
		{
			KillAllRemainingScientists(skipLoot: true);
			Kill();
		}
		if (LoadMode == AILoadMode.KillBoat)
		{
			if (baseBoat is RHIB rHIB)
			{
				rHIB.AdminKillNoLoot(killMountedNPCs: false);
			}
			else
			{
				baseBoat.Kill();
			}
			KillAllRemainingScientists(skipLoot: true);
			Kill();
		}
	}

