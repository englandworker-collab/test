			{
				Debug.Log((object)"Leaving seek state - not a valid target anymore.");
			}
			return false;
		}
		if (!self.IsPlayerInRange(player, self.SearchRange * 1.5f))
		{
			if (BoatAI.PRINT_DEBUGS)
			{
				Debug.Log((object)"Leaving seek state - not in range anymore.");
			}
			return false;
