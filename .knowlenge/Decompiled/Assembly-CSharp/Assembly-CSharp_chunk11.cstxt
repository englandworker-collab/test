	public override bool EngineOn()
	{
		if (!(CurrentThrust() > 0f))
		{
			return !RudderInDeadzone();
		}
		return true;
	}

	private bool RudderInDeadzone()
	{
		return Mathf.Abs(steering) < 0.02f;
	}

	public override bool EngineOnEligible()
	{
		if (EngineOn() && !IsFlipped())
		{
			return base.healthFraction > 0f;
		}
		return false;
	}

