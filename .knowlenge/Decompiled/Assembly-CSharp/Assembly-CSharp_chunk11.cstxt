		Position.Clear();
		AIPoint.Clear();
	}
}


public enum MemoryBankType
{
	Entity,
	Position,
	AIPoint
}


public enum ReservedEntitySlots
{
	Self = 4,
	OwningPlayer,
	GroupLeader,
	SpecialEntity
}


public enum ReservedPositionSlots
