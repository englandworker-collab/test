		ResetTimeSinceUsed();
		((FacepunchBehaviour)this).InvokeRandomized((Action)BoatDecay, Random.Range(30f, 60f), 60f, 6f);
		((FacepunchBehaviour)this).Invoke((Action)StartDeployAndEditCoolDown, 0f);
		timeSinceLastCannonAttack = TimeSince.op_Implicit(100f);
	}

