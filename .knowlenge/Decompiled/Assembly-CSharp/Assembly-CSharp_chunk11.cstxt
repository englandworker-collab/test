			}
			return itemSource.LocalPriceFormatted;
		}
	}

	public string PriceCategory
	{
		get
		{
			IPlayerItemDefinition itemSource = _itemSource;
			if (itemSource == null)
			{
				return null;
			}
			return itemSource.PriceCategory;
		}
	}

