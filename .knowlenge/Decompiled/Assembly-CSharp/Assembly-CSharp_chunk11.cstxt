{
	void OnAddedToBoat(PlayerBoat boat);
}


public interface IBoatPropulsion
{
	float MaxThrust { get; }
}


public interface IDestroyableOnPlayerBoatCollision
{
	bool ShouldBeDestroyedBy(PlayerBoat boat);
}


