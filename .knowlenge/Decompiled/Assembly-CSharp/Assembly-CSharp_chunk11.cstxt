	public void CalculateRepairCost()
	{
		if (BoatBuildingBlocks.Cached == null || BoatBuildingBlocks.Cached.Count == 0)
		{
			return;
		}
		DynamicBuildCost.Clear();
		int num = 0;
		int num2 = 0;
