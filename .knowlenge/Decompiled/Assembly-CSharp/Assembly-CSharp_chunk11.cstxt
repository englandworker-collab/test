					if (!item.MoveToContainer(itemContainer))
					{
						item.Drop(fallbackWorldPos, Vector3.zero, Quaternion.identity);
					}
				}
			}
		}
		Kill();
	}

	public override bool ShouldInheritNetworkGroup()
	{
		return false;
	}
}


