						ulong attacker_id = item.attacker_id;
						string text2 = attacker_id.ToString();
						string text3 = item.attacker;
						if (text3 == "player" && !isAdmin)
						{
							text3 = "player_" + text2;
						}
						attacker_id = item.target_id;
						string text4 = attacker_id.ToString();
						string text5 = item.target;
						if (text5 == "player" && !isAdmin)
						{
							text5 = "player_" + text4;
						}
						string weapon = item.weapon;
						string ammo = item.ammo;
						string text6 = HitAreaUtil.Format(item.area).ToLower();
						float distance = item.distance;
						string text7 = distance.ToString("0.0m");
						distance = item.health_old;
						string text8 = distance.ToString("0.0");
						distance = item.health_new;
						string text9 = distance.ToString("0.0");
						string text10 = item.info;
						if (!player.IsDestroyed && (ulong)player.userID == requestingUser && item.attacker_dead)
						{
							text10 = "you died first (" + text10 + ")";
						}
						int proj_hits = item.proj_hits;
						string text11 = proj_hits.ToString();
						distance = item.proj_integrity;
						string text12 = distance.ToString("0.00");
						distance = item.proj_travel;
						string text13 = distance.ToString("0.00s");
						distance = item.proj_mismatch;
						string text14 = distance.ToString("0.00m");
						proj_hits = item.desync;
						string text15 = proj_hits.ToString();
						if (isAdmin)
						{
							val.AddRow(new string[17]
							{
								text, text3, text2, text5, text4, weapon, ammo, text6, text7, text8,
								text9, text10, text11, text12, text13, text14, text15
							});
						}
						else
						{
							val.AddRow(new string[15]
							{
								text, text3, text5, weapon, ammo, text6, text7, text8, text9, text10,
								text11, text12, text13, text14, text15
							});
						}
					}
					else
					{
						num3++;
					}
				}
			}
			string text16;
			if (json)
			{
				text16 = val.ToJson(true);
			}
			else
			{
				text16 = ((object)val).ToString();
				if (num3 > 0)
				{
					text16 = text16 + "+ " + num3 + " " + ((num3 > 1) ? "events" : "event");
					text16 = text16 + " in the last " + num2 + " " + ((num2 > 1) ? "seconds" : "second");
				}
			}
			return text16;
		}
		finally
		{
			((IDisposable)val)?.Dispose();
		}
	}

	public static Queue<Event> Get(ulong id)
	{
		if (players.TryGetValue(id, out var value))
		{
			return value;
		}
		value = new Queue<Event>();
		players.Add(id, value);
		return value;
	}
}


