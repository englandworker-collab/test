		{
			if (enumerator.MoveNext())
			{
				Item current = enumerator.Current;
				ItemModCompostable itemModCompostable = default(ItemModCompostable);
				if ((((Component)current.info).TryGetComponent<ItemModCompostable>(ref itemModCompostable) ? itemModCompostable.BaitValue : 0f) > 0f)
				{
					item = current;
					itemDefinition = FishLookup.Instance.GetFish(((Component)this).transform.position, cachedWaterBody, current, out var _, ((Component)current.info).GetComponent<ItemModFishable>(), out usedLureAmount, out var _, 5f);
