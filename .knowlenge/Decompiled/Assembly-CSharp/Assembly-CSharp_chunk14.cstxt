			}
			for (int l = 0; l < len1; l++)
			{
				if (l > radius)
				{
					val2.Pop();
				}
				if (l < len1 - radius)
				{
					val2.Push(src[(l + radius) * len2 + y] & srcmask);
				}
				if (val2.Max != 0)
				{
					action(l, y);
				}
			}
		});
	}

