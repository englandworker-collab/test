using System;

[Serializable]
public struct NoiseParameters
{
	public int Octaves;

	public float Frequency;

	public float Amplitude;

	public float Offset;

	public NoiseParameters(int octaves, float frequency, float amplitude, float offset)
	{
		Octaves = octaves;
		Frequency = frequency;
		Amplitude = amplitude;
		Offset = offset;
	}
}


