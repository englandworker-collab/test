	{
		this.x = x;
		this.y = y;
		this.z = z;
	}

	public static Grid FromIndex(int index)
	{
		int num = index / (ChunkCountX * ChunkCountY);
		index -= num * (ChunkCountX * ChunkCountY);
		int num2 = index / ChunkCountX;
		index -= num2 * ChunkCountX;
		return new Grid(index, num2, num);
	}

