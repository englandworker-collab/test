	public int GetTotalItemAmount(Item item, int slotStartInclusive, int slotEndInclusive)
	{
		int num = 0;
		foreach (Item item2 in itemList)
		{
			if (item2.position < slotStartInclusive || item2.position > slotEndInclusive)
			{
				continue;
