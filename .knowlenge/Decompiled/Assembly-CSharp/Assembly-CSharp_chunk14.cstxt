			{
				Debug.LogError((object)$"Held entity for item '{item.info.shortname}' has prefab '{heldEntity.PrefabName}' ({heldEntity.net.ID}) but expected '{entityPrefab.resourcePath}'!!", (Object)(object)heldEntity);
			}
			heldEntity.Kill();
			item.SetHeldEntity(null);
		}
	}

	private bool ParentToParent(Item item, BaseEntity ourEntity)
	{
		Item parentItem = item.parentItem;
		if (parentItem == null)
		{
			return false;
		}
		if (parentItem.IsBackpack())
		{
			return false;
		}
