			TimeWarning val = TimeWarning.New("MissionInstance.TryGetMissionPoint", 0);
			try
			{
				if (identifier == null)
				{
					identifier = string.Empty;
				}
				if (missionPoints.TryGetValue(identifier, out point))
				{
					return true;
				}
