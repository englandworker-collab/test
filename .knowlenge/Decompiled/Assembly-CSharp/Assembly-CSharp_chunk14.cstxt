				Vector3 position = ((Component)missionPoint).transform.position;
				if (((uint)flags2 & (uint)flags) != (uint)flags || (exclusionFlags != 0 && ((uint)flags2 & (uint)exclusionFlags) != 0))
				{
					continue;
