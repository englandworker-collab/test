					int gridIndex2 = GetGridIndex(x2, y2, z2);
					int num7 = result6 * 8 * 8 + result5 * 8 + result4;
					val3 = OcclusionSubGridBlocked[gridIndex2];
					((NativeBitArray)(ref val3)).Set(num7, true);
				}
			}
			hits.Dispose();
		}
		val.Dispose();
		posi.Dispose();
	}
}


