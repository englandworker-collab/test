		if (left.isValid == right.isValid && num * num < num5 && num2 * num2 < num5 && num3 * num3 < num5 && num4 * num4 < num5 && left.artificalWater == right.artificalWater)
		{
			return left.topology == right.topology;
		}
		return false;
	}
}


