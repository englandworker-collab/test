		{
			ResetObjective(index, instance, assignee);
		}
	}
}


using UnityEngine;

public class MissionObjective_OpenStorageContainer : MissionObjective
{
	public BaseEntity TargetEntity;

	[BaseMission.PositionGenerator.PositionPoint]
