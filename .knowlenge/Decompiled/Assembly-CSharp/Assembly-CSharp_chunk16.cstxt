		{
			return;
		}
		if ((int)level != 1)
		{
			if ((int)level == 2)
			{
				Debug.LogError((object)message);
			}
			else
			{
				Debug.Log((object)message);
			}
		}
		else
		{
			Debug.LogWarning((object)message);
		}
		if (exception != null)
		{
			Debug.LogException(exception);
		}
	}
}


