						flag = true;
						AddViolation(basePlayer, AntiHackType.InsideTerrain, ConVar.AntiHack.terrain_penalty);
					}
					else if (ConVar.AntiHack.terrain_check_geometry && IsInsideMesh(basePlayer.eyes.position))
					{
