		return GetIndex(listByType, typeNum);
	}

	public HairSetEntry Get(HairType hairType, float typeNum)
	{
		HairSetEntry[] listByType = GetListByType(hairType);
		return listByType[GetIndex(listByType, typeNum)];
	}
