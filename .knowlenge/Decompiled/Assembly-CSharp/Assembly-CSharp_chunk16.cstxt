			}
		}
		foreach (BaseEntity item in list)
		{
			Debug.Log((object)$"Unparenting {entity}", (Object)(object)entity);
			item.SetParent(null, worldPositionStays: true, sendImmediate: true);
		}
		Pool.FreeUnmanaged<BaseEntity>(ref list);
	}

