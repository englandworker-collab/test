			return;
		}
		allowedItems = items.Where((ItemAmountRanged x) => x.itemDef.IsAllowed((EraRestriction)2)).ToArray();
	}

	public ItemDefinition GetBlueprintBaseDef()
	{
		return ItemManager.FindItemDefinition("blueprintbase");
	}

