		if (!cfg.TryGetValue("$copyFrom", ref val))
		{
			return cfg;
		}
		if ((int)val.Type != 8)
		{
			throw new Exception("Cannot get world config from nexus - zone '" + zoneKey + "' has a $copyFrom, but its value is not a string");
		}
