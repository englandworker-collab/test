		KillerName,
		KillerWeapon,
		AliveTime_Long,
		KillerDistance,
		GenericStat,
		DistanceTravelledWalk,
		DistanceTravelledRun,
		DamageTaken,
		DamageHealed,
		WeaponInfo,
		SecondsWilderness,
		SecondsSwimming,
		SecondsInBase,
