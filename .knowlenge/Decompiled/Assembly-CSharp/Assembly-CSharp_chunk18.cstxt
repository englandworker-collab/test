				if (entity.isServer)
				{
					entity.SendNetworkUpdate();
				}
			}
		}
	}

	public NetworkedProperty(BaseEntity entity)
	{
		this.entity = entity;
	}

	public static implicit operator T(NetworkedProperty<T> value)
	{
		return value.Value;
	}
}


