			shadowmode = _shadowFilteringQuality + 1;
			bool flag = (int)SystemInfo.graphicsDeviceType == 17;
			KeywordUtil.EnsureKeywordState("SHADOW_QUALITY_HIGH", !flag && _shadowFilteringQuality == 2);
			KeywordUtil.EnsureKeywordState("SHADOW_QUALITY_VERYHIGH", !flag && _shadowFilteringQuality == 3);
