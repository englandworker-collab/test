			val.AddColumn("status");
			val.AddColumn("drift");
			BaseBoat[] array = BaseEntity.Util.FindAll<BaseBoat>();
			BaseBoat[] array2 = array;
			foreach (BaseBoat baseBoat in array2)
			{
				if (baseBoat.IsValid())
