		val.spawnOptions = Pool.Get<SpawnOptionsResponse>();
		val.spawnOptions.spawnOptions = Pool.Get<List<SpawnOptions>>();
		BasePlayer.GetRespawnOptionsForPlayer(val.spawnOptions.spawnOptions, base.Request.userId);
		SendSuccess(val);
	}
}


