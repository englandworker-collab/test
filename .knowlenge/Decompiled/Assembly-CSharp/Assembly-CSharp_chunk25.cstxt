	[ServerVar]
	public static void ShowClawMarks(Arg arg)
	{
		bool @bool = arg.GetBool(0, !showClawMarks);
		if (@bool == showClawMarks)
		{
			arg.ReplyWith("Claw marks are already " + (showClawMarks ? "visible" : "hidden") + ".");
			return;
		}
		showClawMarks = @bool;
