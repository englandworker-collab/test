		}
		base.Agent.ResetPath();
		if (!GetMoveDestination(out var destination) || !base.Agent.SetDestinationWithParams(destination, stopAtDestination, speed, (accelerationOverride > 0f) ? new float?(accelerationOverride) : ((float?)null), (decelerationOverride > 0f) ? new float?(decelerationOverride) : ((float?)null), null, null))
		{
			return EFSMStateStatus.Failure;
