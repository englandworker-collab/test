		{
			bots.Remove(this);
			((PersistentObjectWorkQueue<BasePlayer>)botColliderWorkQueue).Remove(this);
			freeBotIds.Add(userID);
		}
		SavePlayerState();
		if (cachedPersistantPlayer != null)
		{
			cachedPersistantPlayer.Dispose();
			cachedPersistantPlayer = null;
		}
	}

