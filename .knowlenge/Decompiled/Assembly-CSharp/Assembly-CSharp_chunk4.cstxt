				{
					TriggerComfort triggerComfort = triggers[i] as TriggerComfort;
					if (!((Object)(object)triggerComfort == (Object)null))
					{
						float num2 = triggerComfort.CalculateComfort(((Component)this).transform.position, this);
						if (num2 > num)
						{
							num = num2;
