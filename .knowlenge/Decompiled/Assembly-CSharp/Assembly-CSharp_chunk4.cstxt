				val.notes.Add(ServerCurrentDeathNote);
			}
			if (State.pointsOfInterest != null)
			{
				val.notes.AddRange(State.pointsOfInterest);
			}
			Interface.CallHook("OnPlayerMarkersSend", (object)this, (object)val);
