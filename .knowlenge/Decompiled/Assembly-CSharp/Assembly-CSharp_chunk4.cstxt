			{
				ForceCastNoClip();
			}
			if (State.toastOnReconnect != null && State.toastOnReconnect.Count > 0)
			{
				((FacepunchBehaviour)this).Invoke((Action)ProcessReconnectToast, 2f);
			}
		}
	}

