			{
				return null;
			}
			if ((Object)(object)NavAgent == (Object)null)
			{
				NavAgent = ((Component)this).GetComponent<RustNavMeshAgent>();
				if ((Object)(object)NavAgent == (Object)null)
				{
					Debug.LogErrorFormat("{0} has no nav agent!", new object[1] { ((Object)this).name });
				}
			}
			return NavAgent;
		}
	}

