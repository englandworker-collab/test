	public static bool IsBotId(ulong id)
	{
		return id < 10000000;
	}

	public static void ReserveBotIds(List<ulong> usedIds)
	{
		usedIds.Sort();
		freeBotIds.Clear();
		ulong num = 1uL;
		foreach (ulong usedId in usedIds)
		{
			for (; num != usedId; num++)
			{
				freeBotIds.Add(num);
			}
			num = usedId + 1;
		}
		botIdCounter = num;
	}
}


