			}
		}
		catch (Exception ex)
		{
			Debug.LogWarning((object)"Server Exception: BasePlayer.BotColliderWorkQueue");
			Debug.LogException(ex);
		}
		static void CleanNulls(ListHashSet<BasePlayer> players, ref PlayerServerStates playerStates)
		{
