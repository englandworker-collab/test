					spawnedAnimal = animal.SpawnedAnimal;
					val2.animal = spawnedAnimal.uid;
					val.animals.Add(val2);
				}
			}
			ClientRPC(RpcTarget.Player("OnReceivedChickenStats", player), val);
		}
		finally
		{
