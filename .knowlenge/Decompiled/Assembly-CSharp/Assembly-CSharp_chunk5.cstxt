public class ChristmasLights : StringLights
{
	public enum AnimationType
	{
		ON = 1,
		FLASHING = 2,
		CHASING = 3,
		FADE = 4,
		SLOWGLOW = 6
	}

	public AnimationType animationStyle = AnimationType.ON;

	public override bool OnRpcMessage(BasePlayer player, uint rpc, Message msg)
	{
