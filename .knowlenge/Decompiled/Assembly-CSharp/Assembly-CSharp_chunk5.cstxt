	{
		List<DroppedItem> entitiesInBuildArea = GetEntitiesInBuildArea<DroppedItem>(BuildArea, -2146959360, server: true);
		foreach (DroppedItem item in entitiesInBuildArea)
		{
			item.OnPhysicsNeighbourChanged();
		}
