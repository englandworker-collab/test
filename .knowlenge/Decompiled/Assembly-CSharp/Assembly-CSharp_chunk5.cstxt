		ClearBusy();
	}

	public void Ignite(Vector3 fromPos)
	{
		Blast(default(RPCMessage));
	}

	public bool CanIgnite()
	{
		return !IsBusy();
	}

	public override void OnAttacked(HitInfo info)
	{
		base.OnAttacked(info);
		if (base.isServer && info.damageTypes.Has(DamageType.Heat))
		{
			Blast(default(RPCMessage));
		}
	}
}


