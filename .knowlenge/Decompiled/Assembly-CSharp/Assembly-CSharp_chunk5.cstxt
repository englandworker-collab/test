	protected override bool ShouldDisplayPickupOption(BasePlayer player)
	{
		bool flag = false;
		if (base.isServer)
		{
			flag = IsOwner(player);
		}
		if (flag && pickup.enabled)
		{
			if (pickup.requireHammer)
			{
				return player.IsHoldingEntity<Hammer>();
