		if (AutoClosePlayerTrigger.contents == null || AutoClosePlayerTrigger.contents.Count == 0)
		{
			if (GetEntitiesInBuildArea<BaseEntity>(BuildArea, -1, base.isServer).Count > 1)
			{
				autoClosePassCount = 0;
