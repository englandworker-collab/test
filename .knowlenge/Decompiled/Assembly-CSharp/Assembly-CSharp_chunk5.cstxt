			return false;
		}
		return true;
	}

	protected override IFuelSystem CreateFuelSystem()
	{
		if (poweredBy == PoweredBy.Fuel)
		{
			return base.CreateFuelSystem();
		}
		return new HumanFuelSystem(base.isServer, this, percentFood);
	}

