		if (!BoatPrefab.isValid)
		{
			return null;
		}
		Quaternion val = CalculateBoatForward(blocks, ents, stationGameObject);
		GetBoatBlocksOBBExtents(blocks, val * Vector3.forward, out var center, out var halfExtents, out var _);
