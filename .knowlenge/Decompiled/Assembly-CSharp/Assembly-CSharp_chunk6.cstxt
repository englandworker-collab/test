	private bool ApplySorting()
	{
		ItemContainer container = Container;
		if (!sortingEnabled)
		{
			return false;
		}
		if (!Server.allowSorting)
		{
			return false;
		}
		bool flag = (Object)(object)cachedParent != (Object)null;
		bool flag2;
		if (flag)
		{
