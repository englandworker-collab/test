	{
		return 0;
	}

	public override bool ItemFilter(Item item, int targetSlot)
	{
		if ((Object)(object)ItemModAssociatedEntity<HeadEntity>.GetAssociatedEntity(item) == (Object)null)
		{
			return false;
		}
		return base.ItemFilter(item, targetSlot);
