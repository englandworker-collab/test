	public override void Save(SaveInfo info)
	{
		base.Save(info);
		info.msg.door = Pool.Get<Door>();
		info.msg.door.canNpcOpen = canNpcOpen;
		info.msg.door.canHandOpen = canHandOpen;
		info.msg.door.isSecurityDoor = isSecurityDoor;
