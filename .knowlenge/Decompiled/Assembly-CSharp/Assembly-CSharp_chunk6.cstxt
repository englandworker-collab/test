		try
		{
			Query.Server.GetInSphere(basePlayer.ServerPosition, 6f, (List<GrowableEntity>)(object)val, Query.DistanceCheckType.Bounds);
			foreach (GrowableEntity item in (List<GrowableEntity>)(object)val)
