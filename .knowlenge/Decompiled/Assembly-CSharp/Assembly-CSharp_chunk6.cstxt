		{
			return 0f;
		}
		if (!IsInsidePortal(entity, portalMode))
		{
			return 0f;
		}
		Transform val = ((portalMode == DeepSeaPortal.PortalModeEnum.Entrance) ? PortalEntranceTransform : PortalExitTransform);
