				if (disableVehiclePhysBoxAction == null)
				{
					disableVehiclePhysBoxAction = DisableVehiclePhysBox;
				}
				float num = (isOpening ? openAnimLength : closeAnimLength);
				((FacepunchBehaviour)this).Invoke(enableVehiclePhysBoxesAction, num * 0.1f);
				((FacepunchBehaviour)this).Invoke(disableVehiclePhysBoxAction, num * 0.8f);
			}
		}
		finally
		{
			((IDisposable)val)?.Dispose();
		}
	}

	private void StopCheckingForBlockages()
	{
		TimeWarning val = TimeWarning.New("StopCheckingForBlockages", 0);
		try
		{
			if (HasVehiclePushBoxes)
			{
				if (disableVehiclePhysBoxAction == null)
				{
					disableVehiclePhysBoxAction = DisableVehiclePhysBox;
				}
