	public float GetWipeEndProgress()
	{
		if (TimeToWipe == 0f || TimeToWipe > DeepSea.wipeEndPhaseDuration)
		{
			return 0f;
		}
		return 1f - Mathf.Clamp01(TimeToWipe / DeepSea.wipeEndPhaseDuration);
	}

