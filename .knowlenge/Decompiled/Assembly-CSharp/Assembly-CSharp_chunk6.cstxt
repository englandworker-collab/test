				using FlagsUpdateScope flagsUpdateScope3 = heldEntity.StartSetFlags(FlagsUpdateMode.SendNetworkUpdate);
				flagsUpdateScope3.Set(Flags.Reserved4, b: false);
			}
			flagsUpdateScope2.Set(Flags.Reserved13, b: false);
		}
		else
		{
			flagsUpdateScope2.Set(Flags.Reserved13, b: false);
		}
	}

