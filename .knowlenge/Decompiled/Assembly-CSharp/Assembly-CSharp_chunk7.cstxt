	public override void OnDied(HitInfo info)
	{
		if (!IsDying)
		{
			using (FlagsUpdateScope flagsUpdateScope = StartSetFlags(FlagsUpdateMode.SendNetworkUpdate))
			{
				flagsUpdateScope.Set(Flags.Broken, b: true);
