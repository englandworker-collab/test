			serverSideBlockPower = Mathf.Clamp(serverSideBlockPower + num / damageToLoseOneSecond, 0f, MaxBlockTime);
			ClientRPC(RpcTarget.Player("ClientUpdateShieldPowerTime", ownerPlayer), serverSideBlockPower / MaxBlockTime);
