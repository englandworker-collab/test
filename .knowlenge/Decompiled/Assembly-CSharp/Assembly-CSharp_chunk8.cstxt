	}

	private void CheckSeatClipping()
	{
		if (_mountedPlayerClipCheck == null)
		{
			_mountedPlayerClipCheck = CheckSeatClipping;
		}
		if (!AnyMounted())
		{
			((FacepunchBehaviour)this).CancelInvokeFixedTime(_mountedPlayerClipCheck);
		}
		else if (IsSeatClipping(this))
		{
			DismountAllPlayers();
			((FacepunchBehaviour)this).CancelInvokeFixedTime(_mountedPlayerClipCheck);
		}
	}

