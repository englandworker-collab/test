	public override bool OnRpcMessage(BasePlayer player, uint rpc, Message msg)
	{
		TimeWarning val = TimeWarning.New("TravellingVendor.OnRpcMessage", 0);
		try
		{
			if (rpc == 831304742 && (Object)(object)player != (Object)null)
