			for (int i = 0; i < cachedServerUpgrades.Count; i++)
			{
				CachedUpgrade cachedUpgrade = cachedServerUpgrades[i];
				cachedUpgrade.mod.ApplyToCraftedItem(this, crafter, task, craftedItem, cachedUpgrade.item);
