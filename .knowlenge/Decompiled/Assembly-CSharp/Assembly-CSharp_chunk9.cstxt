		case 1:
			flag2 = inputAmount != setAmount;
			setAmount = inputAmount;
			break;
		case 2:
			flag2 = inputAmount != resetAmount;
			resetAmount = inputAmount;
			break;
		case 3:
			flag2 = inputAmount != toggleAmount;
			toggleAmount = inputAmount;
			break;
		case 0:
			base.UpdateFromInput(inputAmount, inputSlot);
			UpdateState();
			break;
