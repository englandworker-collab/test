		}
		finally
		{
			((IDisposable)setFlags/*cast due to .constrained prefix*/).Dispose();
		}
		void RefreshFullChargeFlag()
		{
			bool flag3 = (float)Mathf.RoundToInt(rustWattSeconds / 60f) >= maxCapactiySeconds / 60f;
			bool flag4 = HasFlag(Flags.Reserved9);
			if (flag3 && !flag4)
			{
				setFlags.Set(Flags.Reserved9, b: true);
				MarkDirtyForceUpdateOutputs();
