using UnityEngine.InputSystem;

public static class KeyEx
{
	public static string ToShortname(this Key key, bool lowercase = true)
	{
		string text = ((object)(Key)(ref key)/*cast due to .constrained prefix*/).ToString();
		if (text.StartsWith("Digit"))
		{
			text = text.Substring("Digit".Length);
		}
		if (!lowercase)
		{
			return text;
		}
		return text.ToLower();
	}
}


